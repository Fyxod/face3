{
  "description": "FACE default controls. TPS, Delaunay, and rolling are spatial coordinate perturbations. DCT is an image-domain block-frequency gain perturbation. Set enabled=false to turn a perturbation off.",
  "global": {
    "init": "neutral",
    "init_fraction": 0.05,
    "edge_falloff_px": 16.0,
    "max_combined_disp_px": null
  },
  "sizes": {
    "tps_size": 5,
    "delaunay_size": 5,
    "fft_phase_size": 8
  },
  "components": {
    "tps": {
      "enabled": true,
      "norm_limit": 0.008,
      "px_limit": null
    },
    "delaunay": {
      "enabled": true,
      "norm_limit": 0.015,
      "px_limit": null
    },
    "rolling": {
      "enabled": true,
      "norm_limit": 0.01,
      "px_limit": null
    },
    "dct": {
      "enabled": true,
      "mode": "block_frequency_gain",
      "block_size": 8,
      "frequency_mask": "all_ac",
      "exclude_dc": true,
      "gain_limit": 0.5
    },
    "fft_phase": {
      "enabled": false,
      "phase_limit_rad": 3.141592653589793
    }
  }
}
